<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Calculator</title>
    <style>
        * { box-sizing: border-box; font-family: Arial, sans-serif; }
        body {
            margin: 0;
            min-height: 100vh;
            display: grid;
            place-items: center;
            background: #111827;
        }
        .calc {
            width: 320px;
            background: #1f2937;
            padding: 16px;
            border-radius: 16px;
            box-shadow: 0 12px 30px rgba(0, 0, 0, .35);
        }
        #screen {
            width: 100%;
            height: 60px;
            border: 0;
            border-radius: 10px;
            margin-bottom: 12px;
            padding: 0 12px;
            font-size: 2rem;
            text-align: right;
            background: #e5e7eb;
            color: #111827;
        }
        .keys {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 10px;
        }
        button {
            height: 52px;
            border: 0;
            border-radius: 10px;
            font-size: 1.05rem;
            cursor: pointer;
            background: #374151;
            color: #fff;
        }
        button:hover { background: #4b5563; }
        .op { background: #f97316; }
        .op:hover { background: #ea580c; }
        .wide { grid-column: span 2; }
    </style>
</head>
<body>
    <div class="calc">
        <input id="screen" type="text" value="0" readonly>
        <div class="keys">
            <button onclick="clearScreen()">C</button>
            <button onclick="backspace()">⌫</button>
            <button onclick="add('/')" class="op">÷</button>
            <button onclick="add('*')" class="op">×</button>

            <button onclick="add('7')">7</button>
            <button onclick="add('8')">8</button>
            <button onclick="add('9')">9</button>
            <button onclick="add('-')" class="op">−</button>

            <button onclick="add('4')">4</button>
            <button onclick="add('5')">5</button>
            <button onclick="add('6')">6</button>
            <button onclick="add('+')" class="op">+</button>

            <button onclick="add('1')">1</button>
            <button onclick="add('2')">2</button>
            <button onclick="add('3')">3</button>
            <button onclick="result()" class="op">=</button>

            <button onclick="add('0')" class="wide">0</button>
            <button onclick="add('.')">.</button>
        </div>
    </div>

    <script>
        const screen = document.getElementById('screen');

        function add(v) {
            if (screen.value === '0' && /[0-9.]/.test(v)) screen.value = '';
            screen.value += v;
        }

        function clearScreen() {
            screen.value = '0';
        }

        function backspace() {
            screen.value = screen.value.length > 1 ? screen.value.slice(0, -1) : '0';
        }

        function result() {
            try {
                screen.value = Function('return ' + screen.value.replace(/×/g, '*').replace(/÷/g, '/'))();
            } catch {
                screen.value = 'Error';
            }
        }

        document.addEventListener('keydown', (e) => {
            if (/^[0-9.+\-*/]$/.test(e.key)) add(e.key);
            else if (e.key === 'Enter') result();
            else if (e.key === 'Escape') clearScreen();
            else if (e.key === 'Backspace') backspace();
        });
    </script>
</body>
</html>
